# Yandex MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Option 1: Static Token (Simple, but requires manual token renewal)
# =============================================================================
# Get your token from https://oauth.yandex.ru/ with scopes:
# - direct:api (for Yandex Direct)
# - metrika:read, metrika:write (for Yandex Metrika)

# Single token for all services
# YANDEX_TOKEN=your_oauth_token_here

# Or separate tokens per service
# YANDEX_DIRECT_TOKEN=your_direct_token
# YANDEX_METRIKA_TOKEN=your_metrika_token

# For agency accounts - specify client login
# YANDEX_CLIENT_LOGIN=your_client_login

# =============================================================================
# Option 2: OAuth Flow (Automatic token refresh)
# =============================================================================
# Step 1: Go to Yandex OAuth Console
# Navigate to: https://oauth.yandex.ru/
# Log in with your Yandex account if not already logged in.

# Step 2: Create a New Application
# - Application name: Yandex MCP Server
# - Permissions: Select 'direct:api', 'metrika:read', 'metrika:write'
# - Callback URL: https://oauth.yandex.ru/verification_code

# Step 3: Copy your Client ID and Secret
YOUR_CLIENT_ID=your_client_id_here
YOUR_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# Environment Variables
# =============================================================================
# Required for OAuth flow
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret

# Optional: Custom redirect URI (default: oob)
# YANDEX_OAUTH_REDIRECT_URI=https://oauth.yandex.ru/verification_code

# Optional: Custom scopes (default: direct:api,metrika:read,metrika:write)
# YANDEX_OAUTH_SCOPES=direct:api,metrika:read,metrika:write

# Optional: Use sandbox API for testing
# YANDEX_USE_SANDBOX=true